{
  "name": "web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --webpack",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "android:setup": "bash scripts/setup-android.sh",
    "android:sync": "cp android-config/app-build.gradle android/app/build.gradle && cp android-config/AndroidManifest.xml android/app/src/main/AndroidManifest.xml && npx cap sync android",
    "android:open": "bash scripts/open-android.sh",
    "android:build:debug": "npm run android:sync && cd android && chmod +x gradlew && ./gradlew assembleDebug --no-daemon",
    "android:build:aab": "bash build-android-local.sh",
    "android:clean": "cd android && ./gradlew clean --no-daemon",
    "android:run": "bash scripts/run-android.sh"
  },
  "dependencies": {
    "@capacitor/android": "^8.4.1",
    "@capacitor/app": "^8.1.0",
    "@capacitor/browser": "^8.0.3",
    "@capacitor/cli": "^8.4.1",
    "@capacitor/core": "^8.4.1",
    "@capacitor/push-notifications": "^8.1.1",
    "@capgo/capacitor-social-login": "^8.3.36",
    "@swc/helpers": "^0.5.21",
    "canvas-confetti": "^1.9.4",
    "framer-motion": "^12.40.0",
    "html-to-image": "^1.11.13",
    "next": "16.2.4",
    "next-intl": "^4.11.0",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/canvas-confetti": "^1.9.0",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6.0.3",
    "eslint": "^9",
    "eslint-config-next": "16.2.4",
    "jsdom": "^29.1.1",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.1.9"
  }
}
