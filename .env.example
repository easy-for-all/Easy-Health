# PostgreSQL
DB_HOST=db
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=sua_senha_segura

# Rails — copie o valor de api/config/master.key
RAILS_MASTER_KEY=
SECRET_KEY_BASE=

# CORS — origins permitidas (separadas por vírgula)
CORS_ORIGINS=https://easyhealth.art

# Fitness Intelligence — reservado para a futura troca do gerador de treino
USE_FITNESS_INTELLIGENCE_ENGINE=false

# Next.js
NEXT_PUBLIC_API_URL=https://api.easyhealth.art
# Play Store listing for the Android app promo (public). Optional — falls back to
# https://play.google.com/store/apps/details?id=com.EasyHealth.myapp
NEXT_PUBLIC_PLAY_STORE_URL=
# Google Ads conversion label for subscription success (public browser value)
NEXT_PUBLIC_GADS_SUBSCRIPTION_CONVERSION=
# Native Android Google Sign-In: the Web OAuth client ID (same value as
# GOOGLE_CLIENT_ID). Public, safe to expose. Used as serverClientId by the app.
NEXT_PUBLIC_GOOGLE_WEB_CLIENT_ID=

# Sentry — monitoramento de erros
# Backend: obtenha em https://sentry.io → Project → Settings → Client Keys (DSN)
SENTRY_DSN=
# Frontend (exposto ao browser): mesmo DSN do projeto Next.js ou projeto separado
NEXT_PUBLIC_SENTRY_DSN=

# Stripe — pagamentos recorrentes
# Obtenha em: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PRO_MONTHLY=
STRIPE_PRICE_PRO_YEARLY=
FRONTEND_URL=https://easyhealth.art
API_URL=https://easyhealth.art/api

# Make.app — jornadas de relacionamento (outbound: EasyHealth → Make)
# Por segurança, MAKE_WEBHOOK_ALLOWED_EVENTS vazio não envia nenhum evento.
# É só proteção operacional; a config técnica dos eventos vive em
# config/communication_events.yml. Jornada de push V1 (5 eventos):
#   MAKE_WEBHOOK_ALLOWED_EVENTS=first_workout_not_started_2h,first_workout_not_started_24h,first_workout_completed,user_inactive_3_days,user_inactive_7_days
# Detalhes em docs/push-journey-v1.md
MAKE_WEBHOOK_URL=
MAKE_WEBHOOK_SECRET=
MAKE_WEBHOOK_ENABLED=false
MAKE_WEBHOOK_TIMEOUT_SECONDS=10
MAKE_WEBHOOK_PAYLOAD_MODE=minimal
MAKE_WEBHOOK_ALLOWED_EVENTS=
# O bloco push do payload (delivery.channels + push) exige schema v2.
MAKE_EVENT_SCHEMA_VERSION=2
MAKE_EVENT_CHANNEL_ROUTING_ENABLED=false

# Make.app — callback inbound (Make → EasyHealth)
# Segredo compartilhado enviado pelo Make no header X-Make-Secret
MAKE_INBOUND_WEBHOOK_SECRET=

# Make.app — orquestração de push (Make → EasyHealth, POST /api/v1/integrations/make/push_dispatches)
# Com a flag OFF o endpoint responde "orchestration_disabled" sem enviar nada.
MAKE_PUSH_ORCHESTRATION_ENABLED=false
# Bearer token dedicado do endpoint de dispatch (separado do webhook inbound).
# Para rotação sem downtime, defina _CURRENT/_PREVIOUS (ambos aceitos por um período curto).
MAKE_PUSH_DISPATCH_TOKEN=
MAKE_PUSH_DISPATCH_TOKEN_CURRENT=
MAKE_PUSH_DISPATCH_TOKEN_PREVIOUS=
# Limite coarse de dispatches por usuário por minuto (default 10).
MAKE_PUSH_RATE_LIMIT_PER_USER=10
# Etapa B da migração: e-mails autorizados a receber push real via Make (CSV).
MAKE_PUSH_ALLOWED_TEST_EMAILS=mail.marcus.reis@gmail.com

# Firebase Cloud Messaging (FCM HTTP v1) — envio técnico de push (backend).
# Service account NUNCA vai para o Make. Use JSON puro OU a variante Base64.
FIREBASE_SERVICE_ACCOUNT_JSON=
FIREBASE_SERVICE_ACCOUNT_JSON_BASE64=
FIREBASE_PROJECT_ID=easyhealth-analytics

# Push de ativação — scheduler interno legado (Família B). DESATIVADO na V1: a
# jornada de push é orquestrada pelo Make (docs/push-journey-v1.md). Manter false.
ACTIVATION_PUSH_ENABLED=false
ACTIVATION_PUSH_EXPERIMENT_ENABLED=false

# Google AI — POC de geração de vídeo (scripts/generate_exercise_video.py)
# Obtenha em: https://aistudio.google.com/apikey
GOOGLE_API_KEY=

# Vertex AI (alternativa ao GOOGLE_API_KEY)
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service_account.json
# GOOGLE_CLOUD_PROJECT=your-project-id
# GOOGLE_CLOUD_LOCATION=us-central1
