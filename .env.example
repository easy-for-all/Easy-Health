# PostgreSQL
DB_HOST=db
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=sua_senha_segura

# Rails — copie o valor de api/config/master.key
RAILS_MASTER_KEY=
SECRET_KEY_BASE=

# CORS — origins permitidas (separadas por vírgula)
CORS_ORIGINS=https://easyhealth.art

# Fitness Intelligence — reservado para a futura troca do gerador de treino
USE_FITNESS_INTELLIGENCE_ENGINE=false

# Next.js
NEXT_PUBLIC_API_URL=https://api.easyhealth.art
# Google Ads conversion label for subscription success (public browser value)
NEXT_PUBLIC_GADS_SUBSCRIPTION_CONVERSION=
# Native Android Google Sign-In: the Web OAuth client ID (same value as
# GOOGLE_CLIENT_ID). Public, safe to expose. Used as serverClientId by the app.
NEXT_PUBLIC_GOOGLE_WEB_CLIENT_ID=

# Sentry — monitoramento de erros
# Backend: obtenha em https://sentry.io → Project → Settings → Client Keys (DSN)
SENTRY_DSN=
# Frontend (exposto ao browser): mesmo DSN do projeto Next.js ou projeto separado
NEXT_PUBLIC_SENTRY_DSN=

# Stripe — pagamentos recorrentes
# Obtenha em: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PRO_MONTHLY=
STRIPE_PRICE_PRO_YEARLY=
FRONTEND_URL=https://easyhealth.art
API_URL=https://easyhealth.art/api

# Make.app — jornadas de relacionamento (outbound: EasyHealth → Make)
# Por segurança, MAKE_WEBHOOK_ALLOWED_EVENTS vazio não envia nenhum evento.
MAKE_WEBHOOK_URL=
MAKE_WEBHOOK_SECRET=
MAKE_WEBHOOK_ENABLED=false
MAKE_WEBHOOK_TIMEOUT_SECONDS=10
MAKE_WEBHOOK_PAYLOAD_MODE=minimal
MAKE_WEBHOOK_ALLOWED_EVENTS=

# Make.app — callback inbound (Make → EasyHealth)
# Segredo compartilhado enviado pelo Make no header X-Make-Secret
MAKE_INBOUND_WEBHOOK_SECRET=

# Google AI — POC de geração de vídeo (scripts/generate_exercise_video.py)
# Obtenha em: https://aistudio.google.com/apikey
GOOGLE_API_KEY=

# Vertex AI (alternativa ao GOOGLE_API_KEY)
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service_account.json
# GOOGLE_CLOUD_PROJECT=your-project-id
# GOOGLE_CLOUD_LOCATION=us-central1
